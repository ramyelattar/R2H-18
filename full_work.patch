+) {
+    var title by remember { mutableStateOf("") }
+    var body by remember { mutableStateOf("") }
+    var category by remember { mutableStateOf("Fantasy") }
+
+    val categories = listOf("Fantasy", "Memory", "Wish", "Secret")
